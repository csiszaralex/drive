generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model File {
  id           String   @id @default(uuid())
  originalName String
  mimeType     String
  size         Int
  path         String
  createdAt    DateTime @default(now())
}
